# Copy this file to .env.real-github and fill in your GitHub OAuth App credentials.
# Then start the stack with:
#   docker compose -f docker-compose.yaml -f docker-compose.real-github.yml --env-file .env.real-github up --build
#
# To create a GitHub OAuth App:
#   1. Go to https://github.com/settings/developers
#   2. Click "New OAuth App"
#   3. Set "Authorization callback URL" to: http://localhost:8080/api/authentication/callback

GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
