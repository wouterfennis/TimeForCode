@page "/"
@using Microsoft.Extensions.Options
@using TimeForCode.Authorization.Api.Client
@using TimeForCode.Donation.Api.Client
@using TimeForCode.Website.Options
@inject IAuthClient AuthClient
@inject IDonationClient DonationClient
@inject NavigationManager NavigationManager
@inject IOptions<AuthorizationServiceOptions> AuthorizationServiceOptions

<PageTitle>TimeForCode</PageTitle>

<h1>TimeForCode</h1>

@if (_isLoggedIn)
{
    <p>Welcome, <strong>@_userName</strong>!</p>
    <p>Donation API: @_donationResult</p>
    <a href="@_logoutUri">Log out</a>
}
else
{
    <p>You are not logged in.</p>
    <a href="@_loginUri">Log in with GitHub</a>
}

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private bool _isLoggedIn;
    private string? _userName;
    private string? _donationResult;
    private string _loginUri = string.Empty;
    private string _logoutUri = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var publicBaseUri = AuthorizationServiceOptions.Value.EffectivePublicBaseUri;
        var encodedReturnUrl = Uri.EscapeDataString(NavigationManager.Uri);
        _loginUri = $"{publicBaseUri}/api/Authentication/login?IdentityProvider=Github&RedirectUri={encodedReturnUrl}";
        _logoutUri = $"{publicBaseUri}/api/Authentication/logout?RedirectUri={encodedReturnUrl}";

        var cookie = HttpContext?.Request.Cookies["AccessToken"];
        _isLoggedIn = !string.IsNullOrEmpty(cookie);

        if (_isLoggedIn)
        {
            try
            {
                var user = await AuthClient.UserAsync();
                _userName = user.Name;
            }
            catch
            {
                _userName = "(unavailable)";
            }

            try
            {
                _donationResult = await DonationClient.GetAsync();
            }
            catch
            {
                _donationResult = "(unavailable)";
            }
        }
    }
}