@page "/"
@using Microsoft.Extensions.Options
@using TimeForCode.Authorization.Api.Client
@using TimeForCode.Authorization.Api.Client.Extensions
@using TimeForCode.Donation.Api.Client
@using TimeForCode.Website.Options
@inject IAuthClient AuthClient
@inject IDonationClient DonationClient
@inject NavigationManager NavigationManager
@inject IOptions<AuthorizationServiceOptions> AuthorizationServiceOptions

<PageTitle>TimeForCode</PageTitle>

<h1>TimeForCode</h1>

@if (_isLoggedIn)
{
    @if (_isNewUser)
    {
        <div class="alert alert-success">
            Welcome! Your profile has been created. <a href="/profile">View your profile</a>
        </div>
    }
    <p>Welcome, <strong>@_userName</strong>!</p>
    <a href="/profile">Profile</a>
    <a href="/logout">Log out</a>
}
else
{
    <p>You are not logged in.</p>
    <a href="@_loginUri">Log in with GitHub</a>
}

<h2>Published Projects</h2>

@if (_projectsError)
{
    <p>(unavailable)</p>
}
else if (_projects == null)
{
    <p>Loading projects...</p>
}
else if (!_projects.Projects.Any())
{
    <p>No projects yet.</p>
}
else
{
    <div class="project-tiles">
        @foreach (var project in _projects.Projects)
        {
            <div class="project-tile">
                <h3><a href="/projects/@project.Id">@project.FullName</a></h3>
                @if (!string.IsNullOrEmpty(project.Description))
                {
                    <p>@project.Description</p>
                }
                <div class="project-meta">
                    @if (!string.IsNullOrEmpty(project.Language))
                    {
                        <span class="language">@project.Language</span>
                    }
                    <span class="stars" title="Stars">⭐ Stars: @project.StargazersCount</span>
                    <span class="forks" title="Forks">🍴 Forks: @project.ForksCount</span>
                    <span class="issues" title="Open issues">🐛 Open issues: @project.OpenIssuesCount</span>
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private bool _isLoggedIn;
    private bool _isNewUser;
    private string? _userName;
    private GetProjectsResponse? _projects;
    private bool _projectsError;
    private string _loginUri = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var publicBaseUri = AuthorizationServiceOptions.Value.EffectivePublicBaseUri;
        var encodedReturnUrl = Uri.EscapeDataString(NavigationManager.Uri);
        _loginUri = $"{publicBaseUri}/api/Authentication/login?IdentityProvider=Github&RedirectUri={encodedReturnUrl}";

        var cookie = HttpContext?.Request.Cookies["AccessToken"];
        _isLoggedIn = !string.IsNullOrEmpty(cookie);

        if (_isLoggedIn)
        {
            try
            {
                var user = await AuthClient.UserAsync();
                _userName = user.Name;
            }
            catch
            {
                _userName = "(unavailable)";
            }

            var isNewUserCookie = HttpContext?.Request.Cookies["IsNewUser"];
            _isNewUser = isNewUserCookie == "true";
        }

        try
        {
            _projects = await DonationClient.GetProjectsAsync(null, null);
        }
        catch
        {
            _projectsError = true;
        }
    }
}