{
  "openapi": "3.1.1",
  "info": {
    "title": "Authorization API",
    "description": "API to interact with the authorization backend",
    "version": "v1"
  },
  "paths": {
    "/api/Authentication/login": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Login endpoint.",
        "parameters": [
          {
            "name": "IdentityProvider",
            "in": "query",
            "description": "Gets or sets the identity provider for the login request.",
            "schema": {
              "$ref": "#/components/schemas/IdentityProvider"
            }
          },
          {
            "name": "RedirectUri",
            "in": "query",
            "description": "Gets or sets the redirect URI for the login request.",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Found",
            "content": {
              "application/json": { }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    },
    "/api/Authentication/callback": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Callback endpoint that is being called by the external identity provider. After the redirect initiated by Task&lt;IActionResult&gt; AuthenticationController.LoginAsync(LoginRequestModel loginModel).",
        "parameters": [
          {
            "name": "Code",
            "in": "query",
            "description": "Gets or sets the authorization code.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "State",
            "in": "query",
            "description": "Gets or sets the state parameter.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallbackResponseModel"
                }
              }
            }
          },
          "302": {
            "description": "Found",
            "content": {
              "application/json": { }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    },
    "/api/Authentication/logout": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Logout endpoint.",
        "responses": {
          "204": {
            "description": "No Content",
            "content": {
              "application/json": { }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    },
    "/api/Authentication/refresh": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Refresh endpoint.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallbackResponseModel"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    },
    "/.well-known/jwks.json": {
      "get": {
        "tags": [
          "Jwks"
        ],
        "summary": "Returns the JSON Web Key Set (JWKS) for the application.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JwksResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    },
    "/.well-known/openid-configuration": {
      "get": {
        "tags": [
          "OpenIdConfiguration"
        ],
        "summary": "Retrieves the OpenID Connect configuration document.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoveryDocumentResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    },
    "/api/User": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Get user information.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccessToken": {
        "required": [
          "token",
          "expiresAfter"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "expiresAfter": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CallbackResponseModel": {
        "required": [
          "accessToken",
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "accessToken": {
            "description": "The access token.",
            "$ref": "#/components/schemas/AccessToken"
          },
          "refreshToken": {
            "description": "The access token.",
            "$ref": "#/components/schemas/RefreshToken"
          }
        },
        "description": "Represents the model for a callback response."
      },
      "DiscoveryDocumentResponse": {
        "required": [
          "issuer",
          "jwks_uri"
        ],
        "type": "object",
        "properties": {
          "issuer": {
            "type": "string"
          },
          "jwks_uri": {
            "type": "string"
          }
        }
      },
      "IdentityProvider": {
        "type": "integer",
        "description": "Represents the identity providers supported by the application."
      },
      "JwkResponse": {
        "required": [
          "kty",
          "e",
          "n"
        ],
        "type": "object",
        "properties": {
          "kty": {
            "type": "string"
          },
          "e": {
            "type": "string"
          },
          "n": {
            "type": "string"
          }
        }
      },
      "JwksResponse": {
        "required": [
          "keys"
        ],
        "type": "object",
        "properties": {
          "keys": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/JwkResponse"
            }
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RefreshToken": {
        "required": [
          "token",
          "expiresAfter"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "expiresAfter": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UserResponse": {
        "required": [
          "id",
          "login",
          "nodeId",
          "avatarUrl",
          "name",
          "company",
          "email"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User id"
          },
          "login": {
            "type": "string",
            "description": "User login"
          },
          "nodeId": {
            "type": "string",
            "description": "User node id"
          },
          "avatarUrl": {
            "type": "string",
            "description": "User avatar url"
          },
          "name": {
            "type": "string",
            "description": "User name"
          },
          "company": {
            "type": [
              "null",
              "string"
            ],
            "description": "User company"
          },
          "email": {
            "type": "string",
            "description": "User email"
          }
        },
        "description": "User response model"
      }
    }
  },
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Jwks"
    },
    {
      "name": "OpenIdConfiguration"
    },
    {
      "name": "User"
    }
  ]
}