{
  "openapi": "3.1.1",
  "info": {
    "title": "Donation API",
    "description": "API to interact with the donation backend",
    "version": "v1"
  },
  "paths": {
    "/api/v1/Project": {
      "post": {
        "tags": [
          "Project"
        ],
        "summary": "Publishes a GitHub repository as a project.",
        "operationId": "RegisterProject",
        "requestBody": {
          "description": "The project registration request containing the GitHub repository URL.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterProjectRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterProjectRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterProjectRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterProjectResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Project"
        ],
        "summary": "Returns a paginated list of all published projects.",
        "operationId": "GetProjects",
        "parameters": [
          {
            "name": "pageNumber",
            "in": "query",
            "description": "The page number (1-based, default 1).",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The number of items per page (default 20).",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetProjectsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/Project/{id}": {
      "get": {
        "tags": [
          "Project"
        ],
        "summary": "Returns the full details of a published project.",
        "operationId": "GetProjectById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The project identifier.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Project"
        ],
        "summary": "Unpublishes (archives) a previously published project.",
        "operationId": "UnpublishProject",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The project identifier.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content",
            "content": {
              "application/json": { }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GetProjectsResponse": {
        "required": [
          "projects",
          "totalCount",
          "pageNumber",
          "pageSize"
        ],
        "type": "object",
        "properties": {
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectSummaryResponse"
            },
            "description": "The list of projects for the current page."
          },
          "totalCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "The total number of published projects.",
            "format": "int32"
          },
          "pageNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "The current page number (1-based).",
            "format": "int32"
          },
          "pageSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "The number of items per page.",
            "format": "int32"
          }
        },
        "description": "Represents a paginated list of published projects."
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProjectResponse": {
        "required": [
          "id",
          "name",
          "fullName",
          "githubUrl",
          "topics",
          "defaultBranch",
          "ownerLogin",
          "ownerAvatarUrl",
          "createdAt",
          "updatedAt",
          "pushedAt",
          "status"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The internal project identifier."
          },
          "name": {
            "type": "string",
            "description": "The repository name."
          },
          "fullName": {
            "type": "string",
            "description": "The full repository name including owner (e.g. owner/repo)."
          },
          "description": {
            "type": [
              "null",
              "string"
            ],
            "description": "The repository description."
          },
          "githubUrl": {
            "type": "string",
            "description": "The URL to the GitHub repository."
          },
          "language": {
            "type": [
              "null",
              "string"
            ],
            "description": "The primary programming language."
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Repository topics/tags."
          },
          "stargazersCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Number of stars.",
            "format": "int32"
          },
          "forksCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Number of forks.",
            "format": "int32"
          },
          "openIssuesCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Number of open issues.",
            "format": "int32"
          },
          "homepage": {
            "type": [
              "null",
              "string"
            ],
            "description": "The project homepage URL."
          },
          "defaultBranch": {
            "type": "string",
            "description": "The default branch name."
          },
          "license": {
            "type": [
              "null",
              "string"
            ],
            "description": "The SPDX license identifier."
          },
          "ownerLogin": {
            "type": "string",
            "description": "The owner login name."
          },
          "ownerAvatarUrl": {
            "type": "string",
            "description": "The owner avatar URL."
          },
          "createdAt": {
            "type": "string",
            "description": "When the repository was created on GitHub.",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "description": "When the repository was last updated on GitHub.",
            "format": "date-time"
          },
          "pushedAt": {
            "type": "string",
            "description": "When the repository was last pushed to on GitHub.",
            "format": "date-time"
          },
          "status": {
            "description": "The publication status.",
            "$ref": "#/components/schemas/ProjectStatus"
          }
        },
        "description": "Represents full project details."
      },
      "ProjectStatus": {
        "enum": [
          "Published",
          "Archived"
        ]
      },
      "ProjectSummaryResponse": {
        "required": [
          "id",
          "name",
          "fullName",
          "githubUrl",
          "ownerLogin",
          "ownerAvatarUrl"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The internal project identifier."
          },
          "name": {
            "type": "string",
            "description": "The repository name."
          },
          "fullName": {
            "type": "string",
            "description": "The full repository name including owner (e.g. owner/repo)."
          },
          "description": {
            "type": [
              "null",
              "string"
            ],
            "description": "The repository description."
          },
          "githubUrl": {
            "type": "string",
            "description": "The URL to the GitHub repository."
          },
          "language": {
            "type": [
              "null",
              "string"
            ],
            "description": "The primary programming language."
          },
          "stargazersCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Number of stars.",
            "format": "int32"
          },
          "forksCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Number of forks.",
            "format": "int32"
          },
          "openIssuesCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "description": "Number of open issues.",
            "format": "int32"
          },
          "ownerLogin": {
            "type": "string",
            "description": "The owner login name."
          },
          "ownerAvatarUrl": {
            "type": "string",
            "description": "The owner avatar URL."
          }
        },
        "description": "Represents a summary of a published project for list views."
      },
      "RegisterProjectRequest": {
        "required": [
          "githubRepositoryUrl"
        ],
        "type": "object",
        "properties": {
          "githubRepositoryUrl": {
            "type": "string",
            "description": "The Github repository URL of the project.",
            "format": "uri"
          }
        },
        "description": "Represents a request to register a project."
      },
      "RegisterProjectResult": {
        "required": [
          "projectId"
        ],
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Project"
    }
  ]
}